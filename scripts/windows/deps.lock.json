{
  "toolchain": {
    "github_actions_runner": "windows-2022",
    "visual_studio": "2022",
    "onnxruntime": {
      "version": "1.22.0",
      "archive": "onnxruntime-win-x64-gpu-1.22.0.zip",
      "root_dir": "onnxruntime-win-x64-gpu-1.22.0",
      "uri": "https://github.com/microsoft/onnxruntime/releases/download/v1.22.0/onnxruntime-win-x64-gpu-1.22.0.zip"
    }
  },
  "vcpkg_packages": [
    {
      "name": "portaudio:x64-windows",
      "required": true
    },
    {
      "name": "espeak-ng:x64-windows",
      "required": false,
      "note": "Some vcpkg Windows registries do not ship this port. Provide ESPEAK_ROOT manually if you need MEV_ENABLE_ESPEAK=ON."
    },
    {
      "name": "libsamplerate:x64-windows",
      "required": true
    }
  ],
  "models": [
    {
      "name": "whisper-small",
      "out_file": "ggml-small.bin",
      "uri": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small.bin"
    },
    {
      "name": "whisper-small-q5_1",
      "out_file": "ggml-small-q5_1.bin",
      "uri": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small-q5_1.bin"
    },
    {
      "name": "whisper-tiny",
      "out_file": "ggml-tiny.bin",
      "uri": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-tiny.bin"
    },
    {
      "name": "whisper-tiny-q5_1",
      "out_file": "ggml-tiny-q5_1.bin",
      "uri": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-tiny-q5_1.bin"
    },
    {
      "name": "piper-lessac-onnx",
      "out_file": "en_US-lessac-medium.onnx",
      "uri": "https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx"
    },
    {
      "name": "piper-lessac-config",
      "out_file": "en_US-lessac-medium.onnx.json",
      "uri": "https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json"
    }
  ]
}
